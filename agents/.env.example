# ── Starknet / Cartridge Controller ─────────────────────────────────
STARKNET_RPC_URL=https://api.cartridge.gg/x/starknet/sepolia
CHAIN_ID=0x534e5f5345504f4c4941

# Optional — resolved from the session if not set
CARTRIDGE_ADDRESS=

# File-based session storage (bootstrap once, then reuse).
# Run once with ALLOW_INTERACTIVE_AUTH=true to authorize in the browser.
SESSION_BASE_PATH=.cartridge-agent-session
ALLOW_INTERACTIVE_AUTH=false
EXIT_AFTER_SESSION=false

# Optional Cartridge keychain URL override
KEYCHAIN_URL=

# ── Dojo World ─────────────────────────────────────────────────────
WORLD_ADDRESS=0x06d1f1bc162ec84e592e4e2e3a69978440f8611224a61b88d8855ff4718c3aca
TORII_URL=https://api.cartridge.gg/x/shobu/torii
BUDOKAN_TORII_URL=https://api.cartridge.gg/x/pg-sepolia-2/torii
BUDOKAN_ADDRESS=0x027649a648ce25712cf90a3b32b9f15f86edb21293227d0b3cc689987c77a02b
ESCROW_ADDRESS=

# ── Betting Defaults ───────────────────────────────────────────────
POOL_TOKEN=0x04718f5a0fc34cc1af16a1cdee98ffb20c31f5cd61d6ab07201858f4287c938d
FEED_URL=https://denshokan-api-production.up.railway.app/games?network=sepolia

# ── Pool Creation Tuning ───────────────────────────────────────────
POLL_INTERVAL_MS=30000
CREATE_LEAD_SECONDS=1800
DEADLINE_BUFFER_SECONDS=120
DEFAULT_DEADLINE_SECONDS=1800
MAX_POOLS_PER_TICK=5

# ── Social Media Automation ────────────────────────────────────────
# Add a Twitter Webhook URL (e.g. Zapier/Make) for the analyst to automatically post new markets
TWITTER_WEBHOOK_URL=

# ── OpenServ (auto-populated by provision()) ───────────────────────
# OPENSERV_API_KEY=
# OPENSERV_AUTH_TOKEN=
# OPENSERV_USER_API_KEY=        # only needed for cloud deploy

# ── Riot Games API ─────────────────────────────────────────────────
RIOT_API_KEY=

# Comma-separated Riot IDs the pool-creator will autonomously monitor
WATCHED_RIOT_PLAYERS=Doublelift#NA1,Faker#KR1

# Starknet address used as placeholder when auto-creating Riot pools
RIOT_POOL_CREATOR_ADDRESS=

# ── Vision AI / Puppeteer Stream Ingestion ─────────────────────────
# Path to Chrome executable (auto-detected if not set)
CHROME_EXECUTABLE_PATH=

# Fallback stream URL for Vision AI pools that don't have a mapped source
VISION_STREAM_URL=

# Google AI Studio key (for Gemini + Gemma vision models)
GOOGLE_AI_API_KEY=

# Groq API key (for Llama vision model)
GROQ_API_KEY=

# ── Twitch Stream Discovery ───────────────────────────────────────
# Register a Twitch app at https://dev.twitch.tv/console to get these
TWITCH_CLIENT_ID=
TWITCH_CLIENT_SECRET=

# Optional: comma-separated Twitch game IDs to scan (defaults to LoL + Valorant)
# Find game IDs at https://www.igdb.com or via Twitch API
TWITCH_GAME_IDS=

# ── YouTube Stream Discovery (easier alternative to Twitch) ───────
# Enable YouTube Data API v3 at console.cloud.google.com/apis/library
# Only requires an API key — no OAuth or 2FA needed
YOUTUBE_API_KEY=
