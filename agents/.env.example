# ── Starknet / Cartridge Controller ─────────────────────────────────
STARKNET_RPC_URL=https://api.cartridge.gg/x/starknet/sepolia
CHAIN_ID=0x534e5f5345504f4c4941

# Optional — resolved from the session if not set
CARTRIDGE_ADDRESS=

# File-based session storage (bootstrap once, then reuse).
# Run once with ALLOW_INTERACTIVE_AUTH=true to authorize in the browser.
SESSION_BASE_PATH=.cartridge-agent-session
ALLOW_INTERACTIVE_AUTH=false
EXIT_AFTER_SESSION=false

# Optional Cartridge keychain URL override
KEYCHAIN_URL=

# ── Dojo World ─────────────────────────────────────────────────────
WORLD_ADDRESS=0x06d1f1bc162ec84e592e4e2e3a69978440f8611224a61b88d8855ff4718c3aca
TORII_URL=https://api.cartridge.gg/x/shobu/torii
BUDOKAN_TORII_URL=https://api.cartridge.gg/x/pg-sepolia-2/torii
BUDOKAN_ADDRESS=0x027649a648ce25712cf90a3b32b9f15f86edb21293227d0b3cc689987c77a02b
ESCROW_ADDRESS=

# ── Betting Defaults ───────────────────────────────────────────────
POOL_TOKEN=0x04718f5a0fc34cc1af16a1cdee98ffb20c31f5cd61d6ab07201858f4287c938d
FEED_URL=https://denshokan-api-production.up.railway.app/games?network=sepolia

# ── Pool Creation Tuning ───────────────────────────────────────────
POLL_INTERVAL_MS=30000
CREATE_LEAD_SECONDS=1800
DEADLINE_BUFFER_SECONDS=120
DEFAULT_DEADLINE_SECONDS=1800
MAX_POOLS_PER_TICK=5

# ── Social Media Automation ────────────────────────────────────────
# Add a Discord Webhook URL for the analyst to automatically post new markets
DISCORD_WEBHOOK_URL=
# Optional: Add Twitter API v2 Bearer Token to tweet new markets
TWITTER_BEARER_TOKEN=

